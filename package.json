{
  "name": "inventario-csirc-ugr",
  "productName": "Inventario CSIRC UGR",
  "version": "1.0.0",
  "description": "Inventario de ordenadores de aulas — CSIRC, Apoyo a la Docencia, Universidad de Granada",
  "author": "CSIRC UGR",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "dist:dir": "electron-builder --win --dir",
    "dist:portable": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "es.ugr.csirc.inventario",
    "productName": "Inventario CSIRC UGR",
    "files": [
      "main.js",
      "index.html",
      "build/icon.ico"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Inventario CSIRC UGR"
    }
  }
}
